# ----------------------------
# 🚀 Application Configuration
# ----------------------------
ENVIRONMENT="development"      # App environment (development, staging, production)
PORT=5000                      # Port the NestJS server will run on
FBR_BASE_URL=https://gw.fbr.gov.pk
APP_PREFIX="/api"              # Global prefix for all API routes
APP_NAME="YourAppName"         # Friendly app name (used in Swagger/docs)
DOC_PREFIX="/api/docs"         # Swagger docs endpoint

APP_URL=http://localhost:5000  # Backend URL
FRONTEND_URL=http://localhost:3000/ # Frontend URL (React/Next.js client)

# ----------------------------
# 🔑 JWT Configuration
# ----------------------------
AT_KEY=your_jwt_secret_key     # Secret key for signing JWT tokens
AT_EXPIRY=120d                 # Access token expiry (e.g. 15m, 7d, 120d)

# ----------------------------
# 🗄️ Database Configuration
# ----------------------------
DB_HOST=localhost              # Database host (use server IP/host in production)
DB_PORT=5432                   # Postgres port (default: 5432)
DB_USER=postgres               # Database username
DB_PASS=your_db_password       # Database password
DB_NAME=your_db_name           # Database name

# ----------------------------
# 📧 Email / SMTP Configuration
# ----------------------------
EMAIL_HOST=smtp.yourprovider.com   # SMTP host (e.g. smtp.gmail.com, smtp-relay.brevo.com)
EMAIL_PORT=587                     # SMTP port (587 for TLS, 465 for SSL)
EMAIL_USER=your_email@example.com  # SMTP user (your email or API key)
EMAIL_PASS=your_email_password     # SMTP password or API key

# ----------------------------
# 🗂️ Storage Configuration
# ----------------------------
STORAGE_PROVIDER="local"       # Storage type: local | aws
STORAGE_PATH="./media"         # Local storage path for uploads

# -- Required if STORAGE_PROVIDER="aws" --
# STORAGE_REGION=your_region          # AWS region (e.g. us-east-1)
# STORAGE_ENDPOINT=your_endpoint      # Custom S3 endpoint if not AWS
# STORAGE_ACCESS_KEY=your_access_key  # AWS access key
# STORAGE_SECRET_ACCESS_KEY=your_secret_access_key # AWS secret
# STORAGE_S3_BUCKET_NAME=your_bucket_name          # S3 bucket name
